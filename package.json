{
  "name": "nas-md-frontend",
  "private": true,
  "type": "module",
  "description": "Frontend tooling for NAS-MD",
  "scripts": {
    "lint": "eslint web/",
    "lint:fix": "eslint web/ --fix",
    "format": "prettier --write 'web/**/*.{js,css,html}'",
    "format:check": "prettier --check 'web/**/*.{js,css,html}'",
    "test": "playwright test",
    "test:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.3"
  },
  "engines": {
    "node": ">=18"
  }
}
